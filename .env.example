# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# ==============================================================================
# App Configuration
# ==============================================================================
NODE_ENV="development"
HOST=127.0.0.1
PORT=3000
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
ENABLE_SWAGGER=true

THROTTLER_TTL=60
THROTTLER_LIMIT=100

CACHE_TTL=60

# ==============================================================================
# Database
# ==============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/nestjs_api"

# ==============================================================================
# Jwt
# ==============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"

JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_REFRESH_EXPIRATION="7d"

# ==============================================================================
# Redis
# ==============================================================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ==============================================================================
# Object Storage / S3
# ==============================================================================
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Leave endpoint blank for AWS S3
S3_ENDPOINT=""
S3_BUCKET=""
S3_FORCE_PATH_STYLE=false

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL="debug"
LOG_DIR="./logs"
LOG_APP_MAX_SIZE="20m"
LOG_APP_MAX_FILES="14d"
LOG_ERROR_MAX_SIZE="20m"
LOG_ERROR_MAX_FILES="30d"
LOG_TEST_MODE=false

# ==============================================================================
# Open Telemetry / Observability
# ==============================================================================
OTEL_SERVICE_NAME="nestjs-boilerplate"
ENABLE_TRACING=false
ENABLE_METRICS=false
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_TRACES_SAMPLER_ARG=1.0
METRICS_PORT=9464
DB_SLOW_QUERY_THRESHOLD_MS=200