meta {
  name: Update Post by Id
  type: http
  seq: 4
}

patch {
  url: {{host}}/posts/{{post_id}}
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "title": "Edit - {{title}}",
    "content": "Edit - {{content}}",
    "published": {{published}}
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
