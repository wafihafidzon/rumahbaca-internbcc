meta {
  name: Upload Avatar
  type: http
  seq: 6
}

post {
  url: {{host}}/users/{{user_id}}/avatar
  body: multipartForm
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

body:multipart-form {
  file: @file(/media/devnull/DATA WINDOWS/Pictures/Me/AI Generator/Cool Stuff/Compressed/ChatGPT Image Mar 4, 2026, 01_37_31 PM-modified.png)
}

vars:pre-request {
  ~user_id: 
}

settings {
  encodeUrl: true
  timeout: 0
}
